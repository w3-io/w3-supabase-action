{
  "name": "w3-supabase-action",
  "version": "0.1.0",
  "private": true,
  "description": "Supabase integration for W3 workflows: Postgres queries, Auth, Storage, Edge Functions",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/",
    "test": "node --test test/*.test.js",
    "all": "npm run format && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@supabase/supabase-js": "^2.45.0",
    "@w3-io/action-core": "^0.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0"
  }
}
